generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── ENUMS ───────────────────────────────────────────────

enum Role {
  ADMIN
  MANAGER
  TEACHER
  STUDENT
}

enum AssignmentStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
}

enum CefrLevel {
  A1
  A2
  B1
  B2
  C1
  C2
}

enum LessonCategory {
  GENERAL_ENGLISH
  BUSINESS_ENGLISH
  BEGINNERS
  GRAMMAR
  CONVERSATION
  PRONUNCIATION
  VOCABULARY
  EXAM_PREP
  YOUNG_LEARNERS
}

enum QuestionType {
  MULTIPLE_CHOICE
  TRUE_FALSE
  SHORT_ANSWER
  FILL_IN_BLANK
}

enum SessionStatus {
  WAITING
  ACTIVE
  PAUSED
  ENDED
}

// ─── USERS ───────────────────────────────────────────────

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String
  role      Role     @default(STUDENT)
  avatarUrl String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Admin: lessons they created
  createdLessons Lesson[] @relation("LessonCreator")

  // Admin: assignments they made
  createdAssignments Assignment[] @relation("AssignmentCreator")

  // Student: assignments received
  studentAssignments Assignment[] @relation("AssignmentStudent")

  // Teacher: students linked to this teacher
  teacherStudents TeacherStudent[] @relation("Teacher")

  // Student: teachers linked to this student
  studentTeachers TeacherStudent[] @relation("Student")

  // Phase 1: Classroom & Placement
  classroomSessions ClassroomSession[] @relation("SessionTeacher")
  createdTests      PlacementTest[]    @relation("TestCreator")
  studentScores     StudentScore[]     @relation("StudentScores")

  @@map("users")
}

// ─── LESSONS ─────────────────────────────────────────────

model Lesson {
  id          String   @id @default(uuid())
  title       String
  description String?
  contentUrl  String?
  contentType String?
  thumbnail   String?
  cefrLevel   CefrLevel?
  category    LessonCategory @default(GENERAL_ENGLISH)
  teacherNotes String?  // Legacy: single notes field. Per-slide notes now live in slides JSON.

  // Slide-based content: [{ order, title?, contentUrl?, contentType?, teacherNotes? }]
  slides Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  createdBy   String
  creator     User   @relation("LessonCreator", fields: [createdBy], references: [id])

  assignments       Assignment[]
  classroomSessions ClassroomSession[]

  @@map("lessons")
}

// ─── ASSIGNMENTS ─────────────────────────────────────────

model Assignment {
  id     String           @id @default(uuid())
  status AssignmentStatus @default(NOT_STARTED)

  assignedAt  DateTime @default(now())
  completedAt DateTime?

  lessonId String
  lesson   Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  studentId String
  student   User   @relation("AssignmentStudent", fields: [studentId], references: [id], onDelete: Cascade)

  assignedBy String
  assigner   User   @relation("AssignmentCreator", fields: [assignedBy], references: [id])

  @@unique([lessonId, studentId])
  @@map("assignments")
}

// ─── TEACHER ↔ STUDENT LINK ─────────────────────────────

model TeacherStudent {
  id String @id @default(uuid())

  teacherId String
  teacher   User   @relation("Teacher", fields: [teacherId], references: [id], onDelete: Cascade)

  studentId String
  student   User   @relation("Student", fields: [studentId], references: [id], onDelete: Cascade)

  assignedAt DateTime @default(now())

  @@unique([teacherId, studentId])
  @@map("teacher_students")
}

// ─── CLASSROOM SESSIONS ──────────────────────────────────
// Live session: teacher presents slides, students follow in real-time

model ClassroomSession {
  id           String        @id @default(uuid())
  status       SessionStatus @default(WAITING)
  currentSlide Int           @default(0)

  lessonId String
  lesson   Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  teacherId String
  teacher   User   @relation("SessionTeacher", fields: [teacherId], references: [id])

  startedAt DateTime  @default(now())
  endedAt   DateTime?

  @@map("classroom_sessions")
}

// ─── PLACEMENT TESTS ─────────────────────────────────────

model PlacementTest {
  id          String     @id @default(uuid())
  title       String
  description String?
  cefrLevel   CefrLevel?
  isActive    Boolean    @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  createdBy String
  creator   User   @relation("TestCreator", fields: [createdBy], references: [id])

  questions Question[]
  scores    StudentScore[]

  @@map("placement_tests")
}

model Question {
  id     String       @id @default(uuid())
  text   String
  type   QuestionType @default(MULTIPLE_CHOICE)
  order  Int          @default(0)
  points Int          @default(1)

  // JSON for options: [{ label: "A", text: "..." }, ...]
  options       Json?
  correctAnswer String

  testId String
  test   PlacementTest @relation(fields: [testId], references: [id], onDelete: Cascade)

  @@map("questions")
}

model StudentScore {
  id         String     @id @default(uuid())
  score      Int
  maxScore   Int
  cefrResult CefrLevel?

  completedAt DateTime @default(now())

  studentId String
  student   User @relation("StudentScores", fields: [studentId], references: [id], onDelete: Cascade)

  testId String
  test   PlacementTest @relation(fields: [testId], references: [id], onDelete: Cascade)

  @@unique([studentId, testId])
  @@map("student_scores")
}
